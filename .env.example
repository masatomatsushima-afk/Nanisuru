# Nanisuru environment variables
# Copy this file to `.env` and add your real API key:
#   cp .env.example .env
#
# Get a key: https://platform.openai.com/api-keys
# After editing, restart Expo: npx expo start --clear
#
# SECURITY: Never commit `.env` to git.

EXPO_PUBLIC_OPENAI_API_KEY=sk-your-key-here

# Supabase (https://supabase.com/dashboard)
# Authentication > Providers で Google / Apple を有効化してください
# SQL Editor で supabase/SUPABASE_SAFE_SETUP.sql を1回実行してください（全テーブル・RLS・関数を安全に作成）
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 共有リンク用（Webデプロイ時のURL。未設定時は実行中の origin を使用）
# ローカル開発例: EXPO_PUBLIC_APP_URL=http://localhost:8081
# EXPO_PUBLIC_APP_URL=https://your-domain.com

# Google Maps / Places API（プラン生成・旅行秘書の「現在地から探す」）
# プラン生成時、入力した場所（Melbourne、大阪、東京など）の実在スポットを
# Google Places API から取得し、AI はそのリスト内のスポットのみを使用します。
#
# 設定手順:
#   1. https://console.cloud.google.com/ でプロジェクトを作成
#   2. 「APIとサービス」→「ライブラリ」で「Places API (New)」を有効化
#   3. 「認証情報」→「認証情報を作成」→「APIキー」
#   4. APIキーを制限（本番推奨）:
#      - iOS: バンドル ID 制限
#      - Android: パッケージ名 + SHA-1 制限
#      - Web: HTTP リファラー制限
#   5. このファイルを .env にコピー: cp .env.example .env
#   6. 下記にキーを貼り付け
#   7. Expo を再起動: npx expo start --clear
#
# スポットが取得できない場合、アプリは
# 「実在スポットを取得できませんでした」と表示します。
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
